# terraform.tfvars.example
# Copy this to terraform.tfvars and fill in every value.
# terraform.tfvars is gitignored — never commit it.

# ── AWS ──────────────────────────────────────────────────────────────────────
aws_region = "us-east-2"

# ── IB Credentials ───────────────────────────────────────────────────────────
# These are written to Secrets Manager — not stored in Terraform state
ib_username   = "YOUR_IB_USERNAME"
ib_password   = "YOUR_IB_PASSWORD"
ib_account_id = "YOUR_IB_ACCOUNT_ID"
ib_mode       = "paper"    # "paper" or "live" — start with paper

# ── Google OAuth (from Google Cloud Console) ──────────────────────────────────
google_oauth_client_id     = "XXXX.apps.googleusercontent.com"
google_oauth_client_secret = "XXXX"
allowed_google_email       = "your.email@gmail.com"   # ONLY this email can log in

# ── Your Desktop ─────────────────────────────────────────────────────────────
# NinjaTrader machine's public IP — only this IP can call the signal endpoint
# Find yours at: https://whatismyip.com
your_desktop_ip = "YOUR.PUBLIC.IP.HERE"

# ── Alerts ───────────────────────────────────────────────────────────────────
alert_phone_number = "+1XXXXXXXXXX"   # include country code

# ── Risk Defaults ────────────────────────────────────────────────────────────
# These can be adjusted live from the dashboard — these are just startup defaults
max_position_size    = 10
max_daily_loss_usd   = 500
order_cooldown_secs  = 5
max_trade_duration_minutes = 120

# ── Scheduler ────────────────────────────────────────────────────────────────
# Times in UTC. ET = UTC-5 (winter) / UTC-4 (summer)
# 9:00am ET winter = 14:00 UTC
# 4:30pm ET winter = 21:30 UTC
market_open_utc  = "0 14 ? * MON-FRI *"    # ✏️ adjust for daylight saving
market_close_utc = "30 21 ? * MON-FRI *"   # ✏️ adjust for daylight saving
