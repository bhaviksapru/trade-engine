# gateway/config/ibgateway.env.example
# Copy to ibgateway.env and fill in your values.
# ibgateway.env is gitignored — never commit it.
#
# On AWS (EC2), this file is auto-generated at boot from Secrets Manager.
# This file is only needed for LOCAL development with docker-compose.
#
# ── IB Gateway settings ───────────────────────────────────────────────────────
TWS_USERID=YOUR_IB_USERNAME
TWS_PASSWORD=YOUR_IB_PASSWORD
TRADING_MODE=paper          # paper or live — ALWAYS start with paper

# Gateway settings (do not change unless you know what you're doing)
TWS_SETTINGS_PATH=/root/Jts
VNC_SERVER_PASSWORD=changeme   # change this if exposing VNC externally
READ_ONLY_API=no
